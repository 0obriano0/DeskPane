{
  "name": "deskpane",
  "version": "0.3.2",
  "description": "Framework-agnostic web desktop window management engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0obriano0/DeskPane.git"
  },
  "homepage": "https://0obriano0.github.io/DeskPane/",
  "main": "dist/deskpane.umd.js",
  "module": "dist/deskpane.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/deskpane.es.js",
      "require": "./dist/deskpane.umd.js"
    },
    "./desktop": {
      "types": "./dist/desktop.d.ts",
      "import": "./dist/deskpane-desktop.es.js",
      "require": "./dist/deskpane-desktop.umd.js"
    },
    "./workspace": {
      "types": "./dist/workspace.d.ts",
      "import": "./dist/deskpane-workspace.es.js",
      "require": "./dist/deskpane-workspace.umd.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/deskpane-vue.es.js",
      "default": "./dist/deskpane-vue.es.js"
    },
    "./jquery": {
      "types": "./dist/jquery.d.ts",
      "import": "./dist/deskpane-jquery.es.js",
      "require": "./dist/deskpane-jquery.umd.js",
      "default": "./dist/deskpane-jquery.es.js"
    },
    "./styles/*": "./dist/styles/*",
    "./themes/*": "./dist/themes/*"
  },
  "peerDependencies": {
    "jquery": ">=3.0.0",
    "vue": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "jquery": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:lib": "rollup -c rollup.lib.config.mjs && node scripts/build-themes.mjs",
    "clean:pages": "node scripts/clean-pages-builds.mjs",
    "build:pages": "npm run build:lib && npm run clean:pages && npm run build --prefix demo/vue && npm run build --prefix demo/react && npm run build --prefix demo/docs && node scripts/prepare-pages.mjs",
    "build:watch": "tsc --noEmit --watch",
    "dev": "npx http-server . -p 3000 -o /demo/",
    "clean": "node scripts/clean.mjs",
    "release": "npm run clean && npm run build:lib && node scripts/pack-release.mjs"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "http-server": "^14.1.1",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^5.4.0",
    "vue": "^3.5.38"
  },
  "keywords": [
    "window-manager",
    "web-desktop",
    "desktop",
    "floating-window",
    "draggable",
    "resizable",
    "typescript",
    "javascript",
    "jquery",
    "vue",
    "react",
    "ui-framework",
    "framework-agnostic"
  ],
  "license": "Apache-2.0"
}
